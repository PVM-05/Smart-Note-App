rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── HÀM HỖ TRỢ (HELPER FUNCTIONS) ───
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Kiểm tra dữ liệu gửi lên phải chứa user_id chính chủ
    function isValidNote(userId) {
      // request.resource.data đại diện cho cục data mà app đang muốn ghi lên
      return request.resource.data.user_id == userId;
    }

    // ─── QUY TẮC CHÍNH ───
    match /users/{userId} {
      // Quyền trên chính document của user đó
      allow read, write: if isOwner(userId);

      // Collection: Notes
      match /notes/{noteId} {
        // Đọc và Xóa chỉ cần chứng minh mình là chủ
        allow read, delete: if isOwner(userId);
        
        // Tạo mới và Cập nhật: Phải là chủ VÀ data truyền lên phải có user_id chuẩn
        allow create, update: if isOwner(userId) && isValidNote(userId);
      }
      
      // Collection: Tags
      match /tags/{tagId} {
        allow read, write: if isOwner(userId);
      }
      
      // Collection: Media (Lưu metadata của file ảnh/âm thanh)
      match /media/{mediaId} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}